# AdCast Agent 环境变量配置
# 复制为 .env 并填入你的凭证

# 日志级别
ADCAST_LOG_LEVEL=INFO

# 全局预算上限
ADCAST_GLOBAL_BUDGET_LIMIT=10000

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
GOOGLE_ADS_CLIENT_ID=your_client_id
GOOGLE_ADS_CLIENT_SECRET=your_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token

# Meta Ads
META_ACCESS_TOKEN=your_access_token
META_AD_ACCOUNT_ID=your_ad_account_id

# Amazon DSP
AMAZON_CLIENT_ID=your_client_id
AMAZON_CLIENT_SECRET=your_client_secret
AMAZON_REFRESH_TOKEN=your_refresh_token

# 巨量引擎
OCEANENGINE_APP_ID=your_app_id
OCEANENGINE_APP_SECRET=your_app_secret
OCEANENGINE_ACCESS_TOKEN=your_access_token
OCEANENGINE_ADVERTISER_ID=your_advertiser_id

# 腾讯广告
TENCENT_ACCOUNT_ID=your_account_id
TENCENT_ACCESS_TOKEN=your_access_token

# 快手
KUAISHOU_ADVERTISER_ID=your_advertiser_id
KUAISHOU_ACCESS_TOKEN=your_access_token

# 百度
BAIDU_USERNAME=your_username
BAIDU_PASSWORD=your_password
BAIDU_TOKEN=your_api_token
